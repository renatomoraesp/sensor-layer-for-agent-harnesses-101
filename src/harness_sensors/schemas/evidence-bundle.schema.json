{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "evidence-bundle.v1",
  "title": "Harness Evidence Bundle",
  "type": "object",
  "required": [
    "schema_version",
    "repo_path",
    "collected_at",
    "task",
    "git",
    "diff_summary",
    "evidence_availability",
    "test_results",
    "docs",
    "feature_state",
    "runtime",
    "workspace"
  ],
  "properties": {
    "schema_version": {
      "const": "evidence-bundle.v1"
    },
    "repo_path": {
      "type": "string"
    },
    "collected_at": {
      "type": "string",
      "format": "date-time"
    },
    "task": {
      "type": ["object", "null"],
      "properties": {
        "source": {
          "type": ["string", "null"]
        },
        "active_feature_id": {
          "type": ["string", "null"]
        },
        "title": {
          "type": ["string", "null"]
        },
        "status": {
          "type": ["string", "null"]
        },
        "acceptance_criteria": {
          "type": "array"
        },
        "verification": {
          "type": "array"
        },
        "completion_claim": {
          "type": ["string", "null"]
        },
        "notes": {
          "type": ["string", "null"]
        },
        "sprint_contract": {
          "type": ["string", "null"]
        }
      }
    },
    "git": {
      "type": "object"
    },
    "diff_summary": {
      "type": "object",
      "properties": {
        "changed_files": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "changed_tests": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "changed_production_code": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "changed_docs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "changed_harness_state": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "evidence_availability": {
      "type": "object",
      "additionalProperties": {
        "enum": [
          "present",
          "missing",
          "partial",
          "present_not_run",
          "configured_missing",
          "not_configured"
        ]
      }
    },
    "test_results": {
      "type": "object"
    },
    "docs": {
      "type": "object"
    },
    "feature_state": {
      "type": "object"
    },
    "runtime": {
      "type": "object"
    },
    "workspace": {
      "type": "object"
    },
    "metadata": {
      "type": "object"
    }
  }
}
