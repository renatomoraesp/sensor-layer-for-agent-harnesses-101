{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sensor-card.v1",
  "title": "Harness Sensor Card Frontmatter",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "version",
    "trigger",
    "sensor_type",
    "output_schema",
    "evidence"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]*$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "trigger": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "sensor_type": {
      "const": "inferential_feedback_control"
    },
    "output_schema": {
      "const": "sensor-result.v1"
    },
    "maturity": {
      "enum": ["core", "maturity", "experimental"],
      "default": "core"
    },
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["required"],
      "properties": {
        "required": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "optional": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "non_goals": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
